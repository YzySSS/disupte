NODE_ENV=production
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=1
MAX_CONCURRENT_SUBMISSIONS=2

# 在智能表格“接收外部数据”中生成。完整地址等同写入凭证，只能放在服务器环境变量中。
# 如果地址曾出现在聊天、日志或 Git 中，请先在企业微信中重置再配置。
WECOM_SMARTSHEET_WEBHOOK=

# 当前智能表格 Webhook schema 中的字段 ID。
# 两个原因字段是单选，电话号码/投诉内容是文本，投诉图片是图片字段。
WECOM_FIELD_ID_PRIMARY_REASON=ftQMc5
WECOM_FIELD_ID_SECONDARY_REASON=ftk5Tx
WECOM_FIELD_ID_PHONE=ffFwIh
WECOM_FIELD_ID_CONTENT=f04Gwj
WECOM_FIELD_ID_EVIDENCE_IMAGES=fn8TJd
